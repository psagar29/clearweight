CLEARWEIGHT_AI_PROVIDER=auto

# Hosted/public deployments use the OpenAI Responses API by default.
OPENAI_RESPONSES_ENDPOINT=https://api.openai.com/v1/responses
OPENAI_RESPONSES_MODEL=gpt-5.4-mini

# Local development uses Codex OAuth by default.
CODEX_OAUTH_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
CODEX_OAUTH_SCOPE=openid profile email offline_access
CODEX_OAUTH_ORIGINATOR=pi
# Optional for local development. The default public Codex desktop client only
# supports this loopback callback. Hosted deployments need their own allowed
# OAuth client before setting this to an https:// callback.
CODEX_OAUTH_REDIRECT_URI=http://localhost:1455/auth/callback
CODEX_RESPONSES_ENDPOINT=https://chatgpt.com/backend-api/codex/responses
CODEX_RESPONSES_MODEL=gpt-5.4-mini
CLEARWEIGHT_COOKIE_SECRET=replace-with-a-long-random-secret
